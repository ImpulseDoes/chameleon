{
  "name": "@impulsedev/chameleon",
  "version": "3.5.0",
  "description": "highly optimized, memory-efficient, and fully type-safe Discord API library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest",
    "docs": "typedoc",
    "lint": "eslint src example",
    "lint:fix": "eslint src example --fix",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsup src/index.ts --format esm --dts --clean"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "api",
    "chameleon",
    "discord",
    "library",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ImpulseDoes/chameleon"
  },
  "author": "impulsedoes",
  "bugs": {
    "url": "https://github.com/ImpulseDoes/chameleon/issues"
  },
  "homepage": "todo",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  }
}
